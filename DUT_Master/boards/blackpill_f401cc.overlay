/ {
    chosen {
        zephyr,shell-uart = &usart1;
    };
};

/* USART1: PA9 (TX) → USB-TTL RX, PA10 (RX) → USB-TTL TX */
&usart1 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart1_tx_pa9 &usart1_rx_pa10>;
    pinctrl-names = "default";
};

/ {
    testbench_gpios {
        compatible = "gpio-keys";

        tb_pa5: tb_pa5 {
            gpios = <&gpioa 5 GPIO_ACTIVE_HIGH>;
            label = "TB_PA5";
        };
        tb_pb3: tb_pb3 {
            gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>;
            label = "TB_PB3";
        };
        /* add more pins as needed */
    };
};

&gpioa { status = "okay"; };
&gpiob { status = "okay"; };


&adc1 {
    status = "okay";
    #address-cells = <1>;
    #size-cells = <0>;
    pinctrl-0 = <&adc1_in0_pa0 &adc1_in1_pa1>;
    pinctrl-names = "default";
    vref-mv = <3300>;

    channel@0 {
        reg = <0>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <12>;
    };

    channel@1 {
        reg = <1>;
        zephyr,gain = "ADC_GAIN_1";
        zephyr,reference = "ADC_REF_INTERNAL";
        zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
        zephyr,resolution = <12>;
    };
};

/* SPI1: PA5=SCK, PA6=MISO, PA7=MOSI, PA4=CS (software-controlled) */
&spi1 {
    status = "okay";
    pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
    pinctrl-names = "default";
    cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;

    dut_spi: dut@0 {
        compatible = "vnd,spi-device";
        reg = <0>;
        spi-max-frequency = <1000000>;
    };
};

/* USART2: PA2 (TX → DUT RX), PA3 (RX ← DUT TX) */
&usart2 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
    pinctrl-names = "default";
};

/* TIM1 CH1 on PA8 → PWM output to DUT */
&timers1 {
    status = "okay";
    st,prescaler = <0>;

    pwm1: pwm {
        status = "okay";
        pinctrl-0 = <&tim1_ch1_pa8>;
        pinctrl-names = "default";
    };
};

/* TIM2 CH2 on PA1 → PWM input capture from DUT */
&timers2 {
    status = "okay";
    st,prescaler = <0>;

    pwm2: pwm {
        status = "okay";
        pinctrl-0 = <&tim2_ch2_pa1>;
        pinctrl-names = "default";
    };
};